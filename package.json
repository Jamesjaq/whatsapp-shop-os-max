{
  "name": "whatsapp-shop-os-max",
  "version": "1.0.0",
  "description": "The Operating System for Neighborhood Commerce in Kenya",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:load": "node tests/load.test.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:backup": "node scripts/backup-db.js",
    "health:check": "node scripts/health-check.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "whatsapp",
    "commerce",
    "marketplace",
    "kenya",
    "m-pesa",
    "delivery"
  ],
  "author": "Jamesjaq",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "joi": "^17.11.0",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "bull": "^4.11.5",
    "cloudinary": "^1.40.0",
    "twilio": "^3.95.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "validator": "^13.11.0",
    "crypto-js": "^4.2.0",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "vitest": "^1.0.4",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
