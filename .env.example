# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=mysql://root:password@localhost:3306/shop_os_max
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_QUERY_TIMEOUT=30000

# Redis (optional, for caching and job queue)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_PHONE_ID=your_phone_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_TOKEN=your_webhook_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# M-Pesa Daraja
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=123456
MPESA_PASSKEY=your_passkey
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_TIMEOUT_URL=https://your-domain.com/api/mpesa/timeout

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=shop-os-max

# SMS (Twilio for fallback)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin
ADMIN_PHONE=254712345678
ADMIN_EMAIL=admin@example.com

# Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRY=7d
ENCRYPTION_KEY=your_encryption_key_min_32_chars

# Monitoring & Alerts
ALERT_EMAIL=alerts@example.com
ALERT_PHONE=254712345678
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Payment Configuration
PAYMENT_SUCCESS_RATE_THRESHOLD=95
PAYMENT_RETRY_MAX_ATTEMPTS=5
PAYMENT_RETRY_BACKOFF_MS=3000

# Order Configuration
ORDER_SELLER_SLA_MINUTES=5
ORDER_RIDER_SLA_MINUTES=30
ORDER_DELIVERY_TIMEOUT_MINUTES=60

# Dispute Configuration
DISPUTE_ACKNOWLEDGE_SLA_HOURS=1
DISPUTE_INVESTIGATE_SLA_HOURS=4
DISPUTE_RESOLVE_SLA_HOURS=24

# Referral Configuration
SELLER_REFERRAL_BONUS=5
BUYER_REFERRAL_BONUS=50
RIDER_REFERRAL_BONUS=200
RIDER_REFERRAL_DELIVERIES=10

# Rate Limiting
RATE_LIMIT_MESSAGES_PER_MINUTE=100
RATE_LIMIT_ORDERS_PER_MINUTE=10
RATE_LIMIT_API_CALLS_PER_MINUTE=1000

# Feature Flags
FEATURE_INVENTORY_RESERVATION=true
FEATURE_GPS_TRACKING=true
FEATURE_PHOTO_PROOF=true
FEATURE_FRAUD_DETECTION=true
FEATURE_DISPUTE_AUTO_RESOLUTION=true

# Logging
LOG_FORMAT=json
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api/docs

# Timezone
TIMEZONE=Africa/Nairobi
